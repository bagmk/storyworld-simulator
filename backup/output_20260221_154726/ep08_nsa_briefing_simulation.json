    },
    {
      "id": "f0b0c3b7-1379-4edf-86de-91827666835b",
      "episode_id": "ep08_nsa_briefing",
      "turn": 11,
      "speaker_id": "director",
      "speaker_name": "[Scene]",
      "content": "수민은 표를 오래 들여다보다가 조용히, 그 수치들이 실험 결과인지 시뮬레이션인지 물었다. 밀러는 포키샤에서 돌린 결과와 우리가 빌린 외부 QPU 로그를 합친 것이라며, DARPA가 테스트베드를 관리하고 장비 벤더 이름은 보안상 생략되었다고 답했다.",
      "action_type": "director_event",
      "target_id": null,
