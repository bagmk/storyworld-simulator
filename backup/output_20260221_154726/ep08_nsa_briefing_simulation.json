        "relationship_deltas": {
          "kim_sumin": 0.1
        },
        "agenda": "수민이 기술의 사용 목적에 대한 의구심을 계속 질문하도록 유도하고, 자신의 입장을 더욱 확고히 하겠다.",
        "turn_mode": "dialogue",
        "exit_scene": false
