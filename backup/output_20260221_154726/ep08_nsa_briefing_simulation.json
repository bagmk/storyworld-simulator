        },
        "relationship_deltas": {
          "agent_christan_miller": 0.1
        },
        "agenda": "밀러가 이 기술의 통제와 책임에 대해 더 깊이 이야기하도록 유도할 계획이다.",
        "turn_mode": "dialogue",
        "exit_scene": false
      }
