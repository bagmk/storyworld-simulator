    {
      "id": "822e3eeb-b185-4887-b61c-d502773280a9",
      "episode_id": "ep02_nsa_funding",
      "turn": 11,
      "speaker_id": "kim_sumin",
      "speaker_name": "Kim Sumin",
      "content": "*수민은 손에 쥔 서류를 다시 바라보며 깊은 숨을 쉬었다.*  \"Miller 씨, 실제 하드웨어에서의 테스트가 필요합니다. 하지만 연구를 압축하는 건 무리가 있습니다. 시간이 더 필요해요.\"  [이 상황이 점점 더 위험해지고 있다. 밀러의 압박이 느껴진다.]",
      "action_type": "dialogue",
      "target_id": null,
      "timestamp": "2026-02-17T03:20:18.384699",
      "metadata": {
        "emotions": {
