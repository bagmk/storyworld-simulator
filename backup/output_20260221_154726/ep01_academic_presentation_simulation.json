        "turn_mode": "dialogue",
        "exit_scene": false
      }
    },
    {
      "id": "0de865d5-fd48-482c-bdb6-17ecb8aa3b93",
      "episode_id": "ep01_academic_presentation",
      "turn": 7,
      "speaker_id": "alex_moreno",
      "speaker_name": "Dr. Alex Moreno",
      "content": "**모레노가 수민의 질문에 심각한 표정으로 대답한다.**  \"수민, 연구가 다른 이들의 이익과 얽힐 때는 보통 그들이 원하는 결과를 위해 너의 지식과 기술을 이용하려 할 때야. 그건 자금 지원의 조건이 될 수도 있어.\"  [*이런 말이 수민에게 어떤 영향을 미칠지 걱정스럽다.*]",
      "action_type": "dialogue",
      "target_id": null,
